        "graphMode": "none",
        "colorMode": "value"
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "postgresql"
          },
          "format": "table",
          "rawSql": "SELECT COALESCE(SUM(t.input_tokens + t.output_tokens), 0)::bigint AS tokens FROM messages_classified mc JOIN token_usage t ON t.message_uuid = mc.message_uuid WHERE mc.archetype IS NOT NULL AND mc.timestamp >= date_trunc('week', NOW(), 'Europe/Madrid')",
          "refId": "A"
