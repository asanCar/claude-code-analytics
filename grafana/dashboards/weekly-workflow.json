          "format": "table",
          "rawSql": "WITH weekly AS (SELECT date_trunc('week', mc.timestamp, 'Europe/Madrid') AS time, mc.archetype, SUM(t.input_tokens + t.output_tokens)::numeric AS tokens FROM messages_classified mc JOIN token_usage t ON t.message_uuid = mc.message_uuid WHERE mc.archetype IS NOT NULL AND mc.timestamp BETWEEN $__timeFrom() AND $__timeTo() GROUP BY 1, 2), totals AS (SELECT time, SUM(tokens) AS total FROM weekly GROUP BY time) SELECT w.time, w.archetype, (w.tokens / NULLIF(t.total, 0))::float AS share FROM weekly w JOIN totals t ON t.time = w.time ORDER BY w.time",
