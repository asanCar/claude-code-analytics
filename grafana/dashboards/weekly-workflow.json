          "format": "table",
          "rawSql": "WITH this_week AS (SELECT COALESCE(SUM(t.input_tokens + t.output_tokens), 0)::bigint AS tokens FROM messages_classified mc JOIN token_usage t ON t.message_uuid = mc.message_uuid WHERE mc.archetype IS NOT NULL AND mc.timestamp >= date_trunc('week', NOW(), 'Europe/Madrid')), last_week AS (SELECT COALESCE(SUM(t.input_tokens + t.output_tokens), 0)::bigint AS tokens FROM messages_classified mc JOIN token_usage t ON t.message_uuid = mc.message_uuid WHERE mc.archetype IS NOT NULL AND mc.timestamp >= date_trunc('week', NOW(), 'Europe/Madrid') - INTERVAL '7 days' AND mc.timestamp < date_trunc('week', NOW(), 'Europe/Madrid')) SELECT ROUND(100.0 * (tw.tokens - lw.tokens) / NULLIF(lw.tokens, 0), 1) AS wow_pct FROM this_week tw, last_week lw",
          "refId": "A"
        }
