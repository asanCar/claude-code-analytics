          "format": "table",
          "rawSql": "WITH session_archetype AS (SELECT mc.session_id, mc.archetype, SUM(t.input_tokens + t.output_tokens) AS tokens FROM messages_classified mc JOIN token_usage t ON t.message_uuid = mc.message_uuid WHERE mc.archetype IS NOT NULL AND mc.timestamp BETWEEN $__timeFrom() AND $__timeTo() GROUP BY 1, 2), session_dominant AS (SELECT DISTINCT ON (session_id) session_id, archetype FROM session_archetype ORDER BY session_id, tokens DESC) SELECT date_trunc('week', s.started_at, 'Europe/Madrid') AS time, sd.archetype, COUNT(*)::bigint AS sessions FROM session_dominant sd JOIN sessions s ON s.session_id = sd.session_id WHERE s.started_at BETWEEN $__timeFrom() AND $__timeTo() AND s.is_subagent = false GROUP BY 1, 2 ORDER BY 1",
