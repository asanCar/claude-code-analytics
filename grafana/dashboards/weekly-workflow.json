            "uid": "postgresql"
          },
          "format": "table",
          "rawSql": "SELECT date_trunc('week', mc.timestamp, 'Europe/Madrid') AS time, mc.archetype, ROUND(AVG(t.input_tokens + t.output_tokens))::bigint AS avg_tokens FROM messages_classified mc JOIN token_usage t ON t.message_uuid = mc.message_uuid WHERE mc.archetype IS NOT NULL AND mc.timestamp BETWEEN $__timeFrom() AND $__timeTo() GROUP BY 1, 2 ORDER BY 1",
