{
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [],
  "schemaVersion": 39,
  "tags": ["claude-code"],
  "time": {"from": "now-30d", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Overview",
  "uid": "overview",
  "version": 1,
  "templating": {
    "list": [
      {"name": "input_price_opus", "type": "constant", "current": {"value": "5"}, "label": "Opus Input $/MTok", "hide": 0},
      {"name": "output_price_opus", "type": "constant", "current": {"value": "25"}, "label": "Opus Output $/MTok", "hide": 0},
      {"name": "input_price_sonnet", "type": "constant", "current": {"value": "3"}, "label": "Sonnet Input $/MTok", "hide": 0},
      {"name": "output_price_sonnet", "type": "constant", "current": {"value": "15"}, "label": "Sonnet Output $/MTok", "hide": 0},
      {"name": "input_price_haiku", "type": "constant", "current": {"value": "1"}, "label": "Haiku Input $/MTok", "hide": 0},
      {"name": "output_price_haiku", "type": "constant", "current": {"value": "5"}, "label": "Haiku Output $/MTok", "hide": 0}
    ]
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Tokens Over Time",
      "id": 1,
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 0},
      "datasource": {"type": "grafana-postgresql-datasource", "uid": "postgresql"},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 1,
          "custom": {
            "stacking": {"mode": "normal"},
            "fillOpacity": 30
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["sum", "mean"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "datasource": {"type": "grafana-postgresql-datasource", "uid": "postgresql"},
          "format": "table",
          "rawSql": "SELECT date_trunc('day', m.timestamp) AS time, SUM(t.input_tokens) AS input, SUM(t.output_tokens) AS output, SUM(t.cache_read_tokens) AS cache_read, SUM(t.cache_creation_tokens) AS cache_creation FROM token_usage t JOIN messages m ON m.message_uuid = t.message_uuid WHERE m.timestamp BETWEEN $__timeFrom() AND $__timeTo() GROUP BY 1 ORDER BY 1",
          "refId": "A"
        }
      ]
    },
    {
      "type": "barchart",
      "title": "Daily Active Sessions",
      "id": 2,
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "datasource": {"type": "grafana-postgresql-datasource", "uid": "postgresql"},
      "fieldConfig": {
        "defaults": {"unit": "short", "decimals": 0},
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom"},
        "tooltip": {"mode": "single"}
      },
      "targets": [
        {
          "datasource": {"type": "grafana-postgresql-datasource", "uid": "postgresql"},
          "format": "table",
          "rawSql": "SELECT date_trunc('day', started_at) AS time, COUNT(*) AS sessions FROM sessions WHERE started_at BETWEEN $__timeFrom() AND $__timeTo() AND is_subagent = false GROUP BY 1 ORDER BY 1",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Usage Utilization Trend",
      "id": 3,
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "datasource": {"type": "grafana-postgresql-datasource", "uid": "postgresql"},
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "min": 0,
          "max": 100,
          "custom": {}
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "transformations": [
        {
          "id": "partitionByValues",
          "options": {"fields": ["window_name"]}
        }
      ],
      "targets": [
        {
          "datasource": {"type": "grafana-postgresql-datasource", "uid": "postgresql"},
          "format": "table",
          "rawSql": "SELECT timestamp AS time, utilization_pct, window_name FROM usage_snapshots WHERE window_name IN ('five_hour', 'seven_day') AND timestamp BETWEEN $__timeFrom() AND $__timeTo() ORDER BY 1",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Current Plan",
      "id": 4,
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 16},
      "datasource": {"type": "grafana-postgresql-datasource", "uid": "postgresql"},
      "targets": [
        {
          "datasource": {"type": "grafana-postgresql-datasource", "uid": "postgresql"},
          "format": "table",
          "rawSql": "SELECT plan FROM usage_snapshots ORDER BY timestamp DESC LIMIT 1",
          "refId": "A"
        }
      ]
    }
  ]
}
