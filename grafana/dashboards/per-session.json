{
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [],
  "schemaVersion": 39,
  "tags": ["claude-code"],
  "time": {"from": "now-7d", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Per-Session Detail",
  "uid": "per-session",
  "version": 1,
  "templating": {
    "list": [
      {
        "name": "project",
        "type": "query",
        "query": "SELECT DISTINCT project FROM sessions ORDER BY project",
        "datasource": {"type": "grafana-postgresql-datasource", "uid": "postgresql"},
        "hide": 0
      },
      {
        "name": "session",
        "type": "query",
        "query": "SELECT session_id AS __value, session_id || ' (' || started_at::date || ')' AS __text FROM sessions WHERE project = '$project' AND is_subagent = false ORDER BY started_at DESC",
        "datasource": {"type": "grafana-postgresql-datasource", "uid": "postgresql"},
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "type": "stat",
      "title": "human_input",
      "description": "User-typed prompts — the text you write in the Claude Code CLI.",
      "id": 7,
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "datasource": {"type": "grafana-postgresql-datasource", "uid": "postgresql"},
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0, "color": {"mode": "fixed", "fixedColor": "blue"}}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "value_and_name", "graphMode": "none", "colorMode": "value"},
      "targets": [
        {
          "datasource": {"type": "grafana-postgresql-datasource", "uid": "postgresql"},
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS messages FROM messages WHERE session_id = '$session' AND prompt_type = 'human_input'",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "assistant_text",
      "description": "Claude's natural-language replies and reasoning text.",
      "id": 8,
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "datasource": {"type": "grafana-postgresql-datasource", "uid": "postgresql"},
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0, "color": {"mode": "fixed", "fixedColor": "green"}}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "value_and_name", "graphMode": "none", "colorMode": "value"},
      "targets": [
        {
          "datasource": {"type": "grafana-postgresql-datasource", "uid": "postgresql"},
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS messages FROM messages WHERE session_id = '$session' AND prompt_type = 'assistant_text'",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "tool_use",
      "description": "Claude invoking a tool (Read, Write, Edit, Bash, Grep, Glob, etc.). Stored as tool name plus a brief argument summary.",
      "id": 9,
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "datasource": {"type": "grafana-postgresql-datasource", "uid": "postgresql"},
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0, "color": {"mode": "fixed", "fixedColor": "orange"}}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "value_and_name", "graphMode": "none", "colorMode": "value"},
      "targets": [
        {
          "datasource": {"type": "grafana-postgresql-datasource", "uid": "postgresql"},
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS messages FROM messages WHERE session_id = '$session' AND prompt_type = 'tool_use'",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "tool_result",
      "description": "Output a tool returns back to Claude. Stored as tool name plus the first 200 chars of output.",
      "id": 10,
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "datasource": {"type": "grafana-postgresql-datasource", "uid": "postgresql"},
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0, "color": {"mode": "fixed", "fixedColor": "purple"}}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "value_and_name", "graphMode": "none", "colorMode": "value"},
      "targets": [
        {
          "datasource": {"type": "grafana-postgresql-datasource", "uid": "postgresql"},
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS messages FROM messages WHERE session_id = '$session' AND prompt_type = 'tool_result'",
          "refId": "A"
        }
      ]
    },
    {
      "type": "table",
      "title": "Prompt List",
      "description": "Chronological message log for the selected session. Shows each prompt/response with its token cost.",
      "id": 1,
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 4},
      "datasource": {"type": "grafana-postgresql-datasource", "uid": "postgresql"},
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {"matcher": {"id": "byName", "options": "input"}, "properties": [{"id": "unit", "value": "short"}, {"id": "decimals", "value": 1}]},
          {"matcher": {"id": "byName", "options": "output"}, "properties": [{"id": "unit", "value": "short"}, {"id": "decimals", "value": 1}]},
          {"matcher": {"id": "byName", "options": "cache_read"}, "properties": [{"id": "unit", "value": "short"}, {"id": "decimals", "value": 1}]}
        ]
      },
      "targets": [
        {
          "datasource": {"type": "grafana-postgresql-datasource", "uid": "postgresql"},
          "format": "table",
          "rawSql": "SELECT m.timestamp, m.prompt_type, m.tool_name, LEFT(m.prompt_text, 120) AS prompt_preview, COALESCE(t.input_tokens, 0) AS input, COALESCE(t.output_tokens, 0) AS output, COALESCE(t.cache_read_tokens, 0) AS cache_read FROM messages m LEFT JOIN token_usage t ON t.message_uuid = m.message_uuid WHERE m.session_id = '$session' ORDER BY m.timestamp",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Total Input Tokens",
      "description": "Aggregate input tokens for the selected session.",
      "id": 2,
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 14},
      "datasource": {"type": "grafana-postgresql-datasource", "uid": "postgresql"},
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 1}, "overrides": []},
      "targets": [
        {
          "datasource": {"type": "grafana-postgresql-datasource", "uid": "postgresql"},
          "format": "table",
          "rawSql": "SELECT SUM(t.input_tokens) AS total_input FROM messages m LEFT JOIN token_usage t ON t.message_uuid = m.message_uuid WHERE m.session_id = '$session'",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Total Output Tokens",
      "description": "Aggregate output tokens for the selected session.",
      "id": 3,
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 14},
      "datasource": {"type": "grafana-postgresql-datasource", "uid": "postgresql"},
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 1}, "overrides": []},
      "targets": [
        {
          "datasource": {"type": "grafana-postgresql-datasource", "uid": "postgresql"},
          "format": "table",
          "rawSql": "SELECT SUM(t.output_tokens) AS total_output FROM messages m LEFT JOIN token_usage t ON t.message_uuid = m.message_uuid WHERE m.session_id = '$session'",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Total Cache Read Tokens",
      "description": "Aggregate cache read tokens for the selected session.",
      "id": 4,
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 14},
      "datasource": {"type": "grafana-postgresql-datasource", "uid": "postgresql"},
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 1}, "overrides": []},
      "targets": [
        {
          "datasource": {"type": "grafana-postgresql-datasource", "uid": "postgresql"},
          "format": "table",
          "rawSql": "SELECT SUM(t.cache_read_tokens) AS total_cache_read FROM messages m LEFT JOIN token_usage t ON t.message_uuid = m.message_uuid WHERE m.session_id = '$session'",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Message Count",
      "description": "Total number of messages in the selected session.",
      "id": 5,
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 14},
      "datasource": {"type": "grafana-postgresql-datasource", "uid": "postgresql"},
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0}, "overrides": []},
      "targets": [
        {
          "datasource": {"type": "grafana-postgresql-datasource", "uid": "postgresql"},
          "format": "table",
          "rawSql": "SELECT COUNT(m.message_uuid) AS message_count FROM messages m WHERE m.session_id = '$session'",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Session Timeline",
      "description": "Per-prompt token consumption as bars (left axis) with cumulative token consumption over time as lines (right axis). Bars show the tokens used by each individual prompt; lines show the running total per prompt type.",
      "id": 6,
      "gridPos": {"h": 14, "w": 24, "x": 0, "y": 18},
      "datasource": {"type": "grafana-postgresql-datasource", "uid": "postgresql"},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 1,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 0,
            "showPoints": "auto",
            "spanNulls": true,
            "axisPlacement": "right",
            "axisLabel": "Cumulative tokens"
          }
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "cumulative"},
            "properties": [
              {"id": "displayName", "value": "Σ ${__series.name}"}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "per_prompt"},
            "properties": [
              {"id": "custom.drawStyle", "value": "bars"},
              {"id": "custom.fillOpacity", "value": 70},
              {"id": "custom.lineWidth", "value": 10},
              {"id": "custom.barAlignment", "value": 0},
              {"id": "custom.axisPlacement", "value": "left"},
              {"id": "custom.axisLabel", "value": "Per-prompt tokens"},
              {"id": "displayName", "value": "▮ ${__series.name}"},
              {"id": "custom.hideFrom", "value": {"legend": true, "tooltip": false, "viz": false}}
            ]
          }
        ]
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["sum", "max"]},
        "tooltip": {"mode": "multi", "sort": "asc"}
      },
      "transformations": [
        {
          "id": "partitionByValues",
          "filter": {"id": "byRefId", "options": "A"},
          "options": {"fields": ["prompt_type"]}
        },
        {
          "id": "partitionByValues",
          "filter": {"id": "byRefId", "options": "B"},
          "options": {"fields": ["prompt_type"]}
        }
      ],
      "targets": [
        {
          "datasource": {"type": "grafana-postgresql-datasource", "uid": "postgresql"},
          "format": "table",
          "rawSql": "SELECT m.timestamp AS time, m.prompt_type, COALESCE(t.input_tokens, 0) + COALESCE(t.output_tokens, 0) AS per_prompt FROM messages m LEFT JOIN token_usage t ON t.message_uuid = m.message_uuid WHERE m.session_id = '$session' ORDER BY m.timestamp",
          "refId": "B"
        },
        {
          "datasource": {"type": "grafana-postgresql-datasource", "uid": "postgresql"},
          "format": "table",
          "rawSql": "SELECT m.timestamp AS time, m.prompt_type, SUM(COALESCE(t.input_tokens, 0) + COALESCE(t.output_tokens, 0)) OVER (PARTITION BY m.prompt_type ORDER BY m.timestamp ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) AS cumulative FROM messages m LEFT JOIN token_usage t ON t.message_uuid = m.message_uuid WHERE m.session_id = '$session' ORDER BY m.timestamp",
          "refId": "A"
        }
      ]
    }
  ]
}
