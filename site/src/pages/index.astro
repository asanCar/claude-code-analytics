---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import SetupTeaser from '../components/SetupTeaser.astro';
import Footer from '../components/Footer.astro';
import DashboardRow from '../components/DashboardRow.astro';
import DashboardCard from '../components/DashboardCard.astro';
import { featuredDashboards, otherDashboards } from '../content/dashboards';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>claude-code-analytics</title>
    <meta name="description" content="Local analytics for Claude Code. PostgreSQL + Grafana, all on your machine." />
  </head>
  <body>
    <Nav />
    <Hero />
    <Features />
    <SetupTeaser />

    <section id="dashboards">
      <div class="container-wide">
        <h2 style="padding-top: 64px">Dashboards</h2>
        {featuredDashboards.map((d, i) => (
          <DashboardRow dashboard={d} index={i} />
        ))}
      </div>

      <div class="container-wide" style="padding-top: 32px; padding-bottom: 64px">
        <h3>Also included</h3>
        <p class="muted">Four more dashboards ship in the stack — demos coming. Click any tile to view its source.</p>
        <div class="other-grid">
          {otherDashboards.map((d) => <DashboardCard dashboard={d} />)}
        </div>
      </div>
    </section>

    <Footer />

    <style is:global>
      .other-grid {
        margin-top: 16px;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 16px;
      }
    </style>
  </body>
</html>
