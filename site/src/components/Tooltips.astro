---
const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<article class="tip-row">
  <div class="tip-text">
    <h3>Tooltips on every widget</h3>
    <p class="muted">
      Each panel ships with an inline tooltip that explains what the metric is,
      how it's computed, and how to read it. Hover any chart to surface the
      details — no need to leave the dashboard or hunt through docs.
    </p>
  </div>
  <div class="tip-media">
    <figure class="shot">
      <img
        src={`${BASE}/tooltip-example.png`}
        alt="Summary dashboard zoomed into the Work mix per week panel with its tooltip open"
        loading="lazy"
      />
      <figcaption class="muted">
        Hovering the <em>Work mix per week (%)</em> panel on the Summary
        dashboard reveals the per-archetype breakdown for that week.
      </figcaption>
    </figure>
  </div>
</article>

<style>
  .tip-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: start;
    padding: 48px 0 16px;
    border-top: 1px solid var(--border);
    margin-top: 48px;
  }
  .tip-text h3 { margin-bottom: 12px; }
  .shot {
    margin: 0;
    padding: 0;
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    background: var(--surface);
  }
  .shot img { display: block; width: 100%; height: auto; }
  figcaption { padding: 12px 16px; font-size: 13px; }

  @media (max-width: 800px) {
    .tip-row { grid-template-columns: 1fr; gap: 24px; padding: 32px 0 16px; }
  }
</style>
