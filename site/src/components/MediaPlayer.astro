---
type Props = {
  poster: string;
  webm: string;
  mp4: string;
  alt: string;
  width?: number;
  height?: number;
};
const { poster, webm, mp4, alt, width = 1280, height = 800 } = Astro.props;
---
<div class="media">
  <video
    poster={poster}
    autoplay
    loop
    muted
    playsinline
    preload="metadata"
    width={width}
    height={height}>
    <source src={webm} type="video/webm" />
    <source src={mp4} type="video/mp4" />
    <img class="fallback" src={poster} alt={alt} />
  </video>
  <img class="reduced-motion-poster" src={poster} alt={alt} />
</div>

<style>
  .media {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    line-height: 0;
  }
  .media video,
  .media .reduced-motion-poster {
    width: 100%;
    height: auto;
    display: block;
  }
  .media .reduced-motion-poster { display: none; }

  @media (prefers-reduced-motion: reduce) {
    .media video { display: none; }
    .media .reduced-motion-poster { display: block; }
  }
</style>
